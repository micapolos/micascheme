(library (leo predicate)
  (export predicate)
  (import
    (except (scheme) predicate)
    (identifier)
    (leo lookup))

  (define-syntax (predicate $syntax)
    (lambda (lookup?)
      (syntax-case $syntax ()
        ((_ id)
          (safe-lookup? lookup? #'id #'predicate)
          (lookup? #'id #'predicate))
        ((_ id)
          (identifier-append #'id #'id #'?)))))
)
