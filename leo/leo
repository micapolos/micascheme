#!/bin/bash

SOURCE="${BASH_SOURCE[0]}"

# Resolve symlink
while [ -h "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  # If SOURCE was a relative symlink, resolve it relative to the path where the symlink sat
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done

LEO_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"

BASE_DIR="$LEO_DIR/.."
LIB_DIR="$BASE_DIR/lib"
SCHEME_DIR="$LIB_DIR/scheme"

exec "$SCHEME_DIR/bin/scheme" \
    -b "$SCHEME_DIR/lib/petite.boot" \
    -b "$SCHEME_DIR/lib/scheme.boot" \
    --libdirs ".:$LIB_DIR/micascheme" \
    --program "$LIB_DIR/leo.so" \
    "$@"
