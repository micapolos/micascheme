#!/bin/bash
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Define paths relative to the wrapper in bin/
SCHEME_BIN="$HERE/../lib/scheme/bin/scheme"
SCHEME_LIB="$HERE/../lib/scheme/lib"
LEO_SO="$HERE/../lib/leo.so"

# Execute with explicit boot paths
exec "$SCHEME_BIN" \
    -b "$SCHEME_LIB/petite.boot" \
    -b "$SCHEME_LIB/scheme.boot" \
    --program "$LEO_SO" "$@"
